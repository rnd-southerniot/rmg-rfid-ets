# Copy to .env and adjust
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rmg_rfid_ets
PORT=3000
LOG_LEVEL=info

# Required for /api/v1/admin/* endpoints
ADMIN_TOKEN=change-me

# Optional (used by npm run seed)
SEED_FACTORY_CODE=SOUTHERNIOT-DEMO
SEED_FACTORY_NAME=SOUTHERNIOT-DEMO
SEED_LINES=L1,L2
