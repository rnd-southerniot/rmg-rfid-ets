# Copy to .env and adjust
# docker-compose maps host 5434 -> container 5432
DATABASE_URL=postgres://postgres:postgres@localhost:5434/rmg_rfid_ets
PORT=3000
LOG_LEVEL=info

# Required for /api/v1/admin/* endpoints
ADMIN_TOKEN=change-me

# Operator login (firmware → /api/v1/auth/login + /api/v1/auth/check)
# JWT_SECRET: HS256 signing key for issued user tokens (>=16 chars)
# LOGIN_RFID_UIDS: comma-separated hex UIDs of employee cards (uppercase)
JWT_SECRET=replace-with-32-byte-random-secret
LOGIN_RFID_UIDS=8BB85A21,A0C9E5A4

# Optional (used by npm run seed)
SEED_FACTORY_CODE=SOUTHERNIOT-DEMO
SEED_FACTORY_NAME=SOUTHERNIOT-DEMO
SEED_LINES=L1,L2
